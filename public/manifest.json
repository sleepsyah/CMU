{
  "manifest_version": 3,
  "name": "Ellipsis",
  "description": "Understand framing, bias, loaded language, missing perspectives, and plain-language meaning in articles and Congress.gov bills.",
  "version": "0.2.0",
  "key": "",
  "icons": {
    "16": "icons/ellipsis-16.png",
    "24": "icons/ellipsis-24.png",
    "32": "icons/ellipsis-32.png",
    "48": "icons/ellipsis-48.png",
    "128": "icons/ellipsis-128.png"
  },
  "action": {
    "default_title": "Open Ellipsis",
    "default_icon": {
      "16": "icons/ellipsis-16.png",
      "24": "icons/ellipsis-24.png",
      "32": "icons/ellipsis-32.png",
      "48": "icons/ellipsis-48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "nativeMessaging", "scripting", "sidePanel", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
