{
  "manifest_version": 3,
  "name": "Unframed",
  "description": "Understand framing, bias, loaded language, missing perspectives, and plain-language meaning in articles and Congress.gov bills.",
  "version": "0.1.0",
  "action": {
    "default_title": "Open Unframed"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "sidePanel", "storage", "tabs"],
  "host_permissions": ["<all_urls>"]
}
